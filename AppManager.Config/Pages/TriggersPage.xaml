<Page x:Class="AppManager.Config.Pages.TriggersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppManager.Config.Pages"
      d:DataContext="{d:DesignInstance Type=local:TriggersPage}"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Triggers">

	<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="250" />
			<ColumnDefinition Width="5" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- Left Menu Panel -->
		<DockPanel Grid.Column="0">
			<!-- Tag Filter ComboBox -->
			<ComboBox x:Name="TagFilterComboBox" 
                      DockPanel.Dock="Top"
                      Margin="0,0,0,10"
                      SelectionChanged="TagFilterComboBox_SelectionChanged">
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding}" />
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>

			<!-- Triggers Menu List -->
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel>
					<!-- Main Groups Container -->
					<StackPanel x:Name="GroupsStackPanel" />

					<!-- Anonymous Group (outside main groups) -->
					<GroupBox x:Name="AnonymousGroup" 
                              Header="Other"
                              Margin="0,5,0,0"
                              Visibility="Collapsed">
						<StackPanel x:Name="AnonymousStackPanel" />
					</GroupBox>
				</StackPanel>
			</ScrollViewer>
		</DockPanel>

		<!-- Splitter -->
		<GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      Background="LightGray" />

		<!-- Right Content Panel -->
		<Frame x:Name="PageFrame" 
               Grid.Column="2" 
               NavigationUIVisibility="Hidden" />
	</Grid>
</Page>