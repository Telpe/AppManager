<Page x:Class="AppManager.Config.Pages.TriggersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AppManager.Config.Pages"
      d:DataContext="{d:DesignInstance Type=local:TriggersPage}"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Triggers">

	<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="250" />
			<ColumnDefinition Width="5" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- Left Menu Panel -->
		<Grid Grid.Column="0" Margin="5">
			<Grid.RowDefinitions>
				<RowDefinition Height="auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="auto" />
			</Grid.RowDefinitions>
			<!-- Tag Filter ComboBox -->
			<ComboBox x:Name="TagFilterComboBox" 
                      Grid.Row="0"
                      Margin="0,0,0,10"
                      SelectionChanged="TagFilterComboBox_SelectionChanged">
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding}" />
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>

			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="3" HorizontalAlignment="Center" VerticalAlignment="Center"  >
				<DockPanel>
					<StackPanel x:Name="GroupsStackPanel" DockPanel.Dock="Top" />

					<GroupBox x:Name="AnonymousGroup" 
							DockPanel.Dock="Bottom"
							Header="Other"
							Margin="0"
							Visibility="Collapsed"
							HorizontalAlignment="Center" 
							VerticalAlignment="Center">
						<StackPanel x:Name="AnonymousStackPanel" HorizontalAlignment="Center" VerticalAlignment="Stretch" />
					</GroupBox>
				</DockPanel>

			</ScrollViewer>
				
			<Button Content="Add Trigger"
				Grid.Row="2"
				Margin="3" 
				Padding="3"
				Click="AddTriggerButton_Click" VerticalAlignment="Center" />
		</Grid>

		<!-- Splitter -->
		<GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      Background="LightGray" />

		<ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" >
			<Frame x:Name="PageFrame" NavigationUIVisibility="Hidden" />
		</ScrollViewer>
	</Grid>
</Page>