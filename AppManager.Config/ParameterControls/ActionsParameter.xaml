<parametercontrols:BaseParameterControl 
                x:Class="AppManager.Config.ParameterControls.ActionsParameter"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:parametercontrols="clr-namespace:AppManager.Config.ParameterControls" 
                d:DataContext="{d:DesignInstance Type=parametercontrols:ActionsParameter}"
                mc:Ignorable="d" 
                d:DesignHeight="200" d:DesignWidth="400">

	<Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition MinHeight="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,5">
			<Button Content="Add Action" Width="100" Height="25" 
                    Click="AddActionButton_Click"/>
        </WrapPanel>

        <TextBox    Grid.Row="0"
			Grid.Column="1"
			Style="{StaticResource ReadOnlyLabelTextBoxStyle}"
			Text="{Binding LabelText, Mode=OneTime}" 
			Margin="0,0,3,0"/>

        <ListBox x:Name="ActionsListBox" Grid.Row="1" Grid.Column="0">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock x:Name="DisplayTextBlock" Grid.Column="0" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Content="Edit" Width="60" Height="20" Margin="0,0,5,0"
                                Click="EditActionButton_Click" Tag="{Binding}"/>
						<Button Grid.Column="2" Content="Remove" Width="60" Height="20" 
                                Click="RemoveActionButton_Click" Tag="{Binding}"/>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

        <TextBox    Grid.Row="1"
					Grid.Column="1"
					Grid.RowSpan="2"
					Style="{StaticResource ReadOnlyDescriptionTextBoxStyle}"
					Text="{Binding Description, Mode=OneTime}"
					Margin="0,0,0,0"/>
    </Grid>
</parametercontrols:BaseParameterControl>