<UserControl x:Class="AppManager.Config.EditorControls.ConditionEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AppManager.Config.EditorControls"
			 xmlns:parameterControls="clr-namespace:AppManager.Config.ParameterControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="10">
            <!-- Condition Type Section -->
			<GroupBox Header="Condition Type:" Margin="0,0,0,10">
				<StackPanel x:Name="TypeSelectionPanel" Orientation="Horizontal" Margin="5"/>
			</GroupBox>

			<StackPanel x:Name="ConditionParameters" Orientation="Vertical" Grid.Row="2" Margin="5"/>

            <!-- Action Buttons -->
            <WrapPanel HorizontalAlignment="Right" Margin="5">
                <Button x:Name="SaveButton" Content="Save" Width="75" Height="25" 
                        Margin="5,0,5,0" Click="SaveButton_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="75" Height="25" 
                        Margin="5,0,0,0" Click="CancelButton_Click"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
