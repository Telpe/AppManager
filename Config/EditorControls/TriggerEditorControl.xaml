<UserControl
	x:Class="AppManager.Config.EditorControls.TriggerEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:local="clr-namespace:AppManager.Config.EditorControls"
	xmlns:parameterControls="clr-namespace:AppManager.Config.ParameterControls"
	d:DataContext="{d:DesignInstance Type=local:TriggerEditorControl}"
    mc:Ignorable="d" 
    d:DesignHeight="500" d:DesignWidth="600">

	<StackPanel Orientation="Vertical" Margin="10">
		
		<GroupBox x:Name="TypeSelectionGroupBox" Header="Trigger Type" Margin="5"/>

		<GroupBox x:Name="TriggerTags" Header="Tags:" Margin="5"/>
		
		<GroupBox x:Name="TriggerConditions" Header="Conditions:" Margin="5"/>

		<GroupBox x:Name="TriggerActions" Header="Actions:" Margin="5"/>

		<StackPanel x:Name="TriggerParameters" Orientation="Vertical" Margin="5"/>

		<!-- Preview Section -->
		<GroupBox Header="Configuration Preview" Margin="5">
			<ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
				<TextBlock x:Name="PreviewTextBlock" 
                           TextWrapping="Wrap" 
                           Background="LightGray" 
                           Padding="5" 
                           FontFamily="Consolas"
                           Margin="5"/>
			</ScrollViewer>
		</GroupBox>

		<!-- Action Buttons -->
		<WrapPanel HorizontalAlignment="Right" Margin="5">
			<Button Content="Run Actions" Width="80" Height="25" Margin="0,0,5,0"
                    Click="TestTriggerButton_Click"/>
			<Button x:Name="SaveTriggerButton" Content="Save" Width="75" Height="25" 
                    Margin="5,0,5,0" Click="SaveButton_Click"/>
			<Button x:Name="CancelTriggerButton" Content="Cancel" Width="75" Height="25" 
                    Margin="5,0,0,0" Click="CancelButton_Click"/>
		</WrapPanel>
	</StackPanel>
</UserControl>