<parametercontrols:BaseParameterControl 
        x:Class="AppManager.Config.ParameterControls.BooleanParameter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:parametercontrols="clr-namespace:AppManager.Config.ParameterControls" 
        d:DataContext="{d:DesignInstance Type=parametercontrols:BooleanParameter}"
        mc:Ignorable="d" 
        d:DesignHeight="120" d:DesignWidth="400">

	<Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBox    Grid.Row="0"
			Grid.Column="0"
			Style="{StaticResource ReadOnlyLabelTextBoxStyle}"
			Text="{Binding LabelText, Mode=OneTime}" 
			Margin="0,0,3,0"/>
        
        <CheckBox Grid.Row="1" Grid.Column="1"
                  x:Name="ValueCheckBox"
                  IsChecked="{Binding Value, Mode=TwoWay}"
                  IsThreeState="True"
                  Checked="CheckBox_Changed"
                  Unchecked="CheckBox_Changed"
                  Margin="0,5,0,0"
                  Content="{Binding LabelText}"/>

        <TextBox    Grid.Row="0"
		    Grid.Column="2"
		    Grid.RowSpan="2"
			Style="{StaticResource ReadOnlyDescriptionTextBoxStyle}"
		    Text="{Binding Description, Mode=OneTime}"
		    Margin="0,0,0,0"/>
    </Grid>
</parametercontrols:BaseParameterControl>