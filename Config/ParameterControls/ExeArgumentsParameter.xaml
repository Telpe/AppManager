<parametercontrols:BaseParameterControl 
                x:Class="AppManager.Config.ParameterControls.ExeArgumentsParameter"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:parametercontrols="clr-namespace:AppManager.Config.ParameterControls" 
	            d:DataContext="{d:DesignInstance Type=parametercontrols:ExeArgumentsParameter}"
                mc:Ignorable="d" 
                d:DesignHeight="120" d:DesignWidth="400">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="{Binding LabelText}" 
                   Margin="0,0,0,3"/>

        <TextBox Grid.Row="0"  Grid.Column="1"
                 x:Name="ArgumentsTextBox"
                 Text="{Binding Value}"
                 TextChanged="ArgumentsTextBox_TextChanged"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 MaxLength="32698"
                 MinHeight="60"/>

        <TextBox    Grid.Row="0"
		    Grid.Column="2"
		    Grid.RowSpan="2"
			Style="{StaticResource ReadOnlyDescriptionTextBoxStyle}"
		    Text="{Binding Description, Mode=OneTime}"
		    Margin="0,0,0,0"/>
    </Grid>
</parametercontrols:BaseParameterControl>