<parametercontrols:BaseParameterControl 
    x:Class="AppManager.Config.ParameterControls.KeybindCaptureParameter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:parametercontrols="clr-namespace:AppManager.Config.ParameterControls"
	d:DataContext="{d:DesignInstance Type=parametercontrols:KeybindCaptureParameter}"
    mc:Ignorable="d" 
    d:DesignHeight="100" d:DesignWidth="400">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
			<ColumnDefinition Width="auto"/>
			<ColumnDefinition Width="2*"/>
		</Grid.ColumnDefinitions>

        <TextBox    Grid.Row="0"
			Grid.Column="0"
			Style="{StaticResource ReadOnlyLabelTextBoxStyle}"
			Text="{Binding LabelText, Mode=OneTime}" 
			Margin="0,0,3,0"/>
        
		<TextBox x:Name="KeybindTextBox" 
                 Grid.Row="0" Grid.Column="1" 
                 Margin="0,0,5,0" 
                 VerticalAlignment="Center" 
                 Height="25" 
                 IsReadOnly="True"/>

		<Button x:Name="CaptureButton" 
                Content="Capture" 
                Grid.Row="0" Grid.Column="2" 
                Width="80" Height="25"
                Click="CaptureButton_Click"/>

        <TextBox    Grid.Row="0"
		    Grid.Column="3"
		    Grid.RowSpan="2"
			Style="{StaticResource ReadOnlyDescriptionTextBoxStyle}"
		    Text="{Binding Description, Mode=OneTime}"
		    Margin="0,0,0,0"/>
    </Grid>
</parametercontrols:BaseParameterControl>