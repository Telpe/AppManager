<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style x:Key="SelectableTextBlockStyle" TargetType="TextBox">
		<Setter Property="IsReadOnly" Value="True"/>
		<Setter Property="Cursor" Value="Arrow"/>
		<Setter Property="BorderThickness" Value="0"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Padding" Value="0"/>
		<Setter Property="Margin" Value="0"/>
		<Setter Property="TextWrapping" Value="Wrap"/>
		<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		<Style.Triggers>
			<Trigger Property="IsFocused" Value="True">
				<Setter Property="Background" Value="Transparent"/>
			</Trigger>
		</Style.Triggers>
	</Style>

    <Style x:Key="MenuItemSelectedHighlight" TargetType="Button">
        <Setter Property="BorderBrush" Value="Blue"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Parameter Control TextBox Styles -->
	<Style x:Key="ReadOnlyLabelTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SelectableTextBlockStyle}">
		<Setter Property="Height" Value="25" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="MinWidth" Value="40" />
		<Setter Property="MaxWidth" Value="200" />
	</Style>

	<Style x:Key="InputTextBoxStyle" TargetType="TextBox">
		<Setter Property="MinWidth" Value="100" />
		<Setter Property="MaxWidth" Value="200" />
		<Setter Property="Height" Value="25" />
		<Setter Property="VerticalAlignment" Value="Top" />
	</Style>

	<Style x:Key="ReadOnlyDescriptionTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SelectableTextBlockStyle}">
		<Setter Property="MinHeight" Value="25" />
		<Setter Property="VerticalAlignment" Value="Top" />
	</Style>
</ResourceDictionary>